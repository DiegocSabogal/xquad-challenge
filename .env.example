# ============================================================
# CONFIGURACION DEL SISTEMA - FinServ LATAM Compliance Agent
# Copiar a .env y completar los valores
# ============================================================

# --- LLM ---
# Opcion A: Claude (Anthropic) - usado en este challenge
ANTHROPIC_API_KEY=sk-ant-...

# Opcion B: Vertex AI (Gemini) - opcion de produccion recomendada para GCP
# GOOGLE_CLOUD_PROJECT=finserv-latam-prod
# GOOGLE_CLOUD_REGION=us-central1
# VERTEX_AI_LOCATION=us-central1

# --- Modo de ejecucion ---
# "mock"    -> sin API keys, respuestas simuladas (default)
# "claude"  -> usa Anthropic Claude API
# "gemini"  -> usa Vertex AI Gemini
LLM_MODE=mock

# --- Langfuse (Observabilidad) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# --- Vector Store (ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
